##In essence, the file managers purpose is to make sure that the right files are saved and managed proplery
## NOTE: Something to keep in mind is that static things should be stored in the res:// directory and things like save data
## and user history should be stored in user://


#region Variables
#Establishes a reference to the player save data
const save_directory = "user://Player Data/Saves/"
#Save data file path
var save_data_file_path: String = "user://Player Data/Saves/save_data.json"
#References the temporary data folder which contain most generated resources
const temporary_directory = "user://Player Data/Temporary Data/"
#Meant to refernce the history file generated by the player
var history_file = temporary_directory + "history.json"
#Default values for the save data file
var save_data_default = {
	"Scene Info": [],          # List of scene dictionaries
	"Object Info": [],         # List of objects
	"Player Info": [],         # List of players
	"Dialogue Info": []        # List of dialogue states
}
#Regex meant to catch floats inside of a string
var regex: RegEx
	#region Requested Save Data
#Holds the rquested dialogue data for the save function
