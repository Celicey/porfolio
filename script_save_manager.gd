## Makes sure that the necesary folders are there and if not makes them.
func _ready() -> void:
	#Ensures that the temporary data folder is there
	var user_directory = DirAccess.open("user://")
	var relative_path_temporary_data = temporary_directory.get_base_dir().trim_prefix("user://")
	var relative_path_save_directory = save_directory.get_base_dir().trim_prefix("user://")
	
	#Checks if the temporary_directory exists and if not, makes it.
	if not user_directory.dir_exists(relative_path_temporary_data):
		var new_directory = user_directory.make_dir_recursive(relative_path_temporary_data)
		if new_directory != OK:
			push_error("Failed to find path or create Temporary Data Folder")
	#Checks if the save_directory exists and if not, makes it.
	if not user_directory.dir_exists(relative_path_save_directory):
		var new_directory = user_directory.make_dir_recursive(relative_path_save_directory)
		if new_directory != OK:
			push_error("Failed to find path or create Temporary Data Folder")
	#Regex initialization 
	regex = RegEx.new()
	regex.compile(r"-?\d+(\.\d+)?")
	#Connects the recieve_save_data function to the emissions of save info so that it can record the save information from relevent parties
	autoload_script_signal_manager.connect("send_save_info", receive_save_data)


## Contains the functions used to save and help save the game
#region Save Game Functionality
## Saves the game
func save_game(save_name: String) -> void:
	var save_path = save_directory.path_join(save_name)
	print("Save Directory: ", save_path)
	#region Save Folder Management
	#Checks to confirm if the save directory itself is detected
	if not DirAccess.dir_exists_absolute(save_directory):
		push_error("Save directory not found at: ", save_directory)
		return
	#Checks for duplicates, and if there are, overwrites them
	if DirAccess.dir_exists_absolute(save_path):
		var overwrite_dir = DirAccess.open(save_path)
		#Starts a stream that allows you to use .get_next() to itterate through the whole file list
		overwrite_dir.list_dir_begin()
		#Isolates the name of the file
		var file = overwrite_dir.get_next()
		while file != "":
			if not overwrite_dir.current_is_dir():
				overwrite_dir.remove(file)
			file = overwrite_dir.get_next()
		#Closes the directory stream to ensure it is closed
		overwrite_dir.list_dir_end()
		print("Overwrite Complete, files in: ", save_path, " deleted.")
	#Checks to see if the folder was created, and if not, it pushes an error
	else:
		var save_folder = DirAccess.make_dir_absolute(save_path)
		if save_folder == OK:
			print("Save folder: ", save_name, " created at: ", save_path)
		else:
			push_error("Failed to create save folder: ", save_path)
	#After the code clears this segment, it starts saving files to the designated folder
	#Code that copies and saves the history files
	#endregion Save Folder Management
	#region Save File Creation and Management
		#region Save Date & Time
	#Grabs the system time and date and mashes them together in a string
	var date: String = Time.get_date_string_from_system(false)
	var time: String = Time.get_time_string_from_system(false)
	var date_time: String = date + " " + time
	#Save ID - Creates a config file that stores the creation date of the save using system time
	var save_id = ConfigFile.new()
	save_id.set_value("Save ID Values", "Save Date", date_time)
	var path_save_id = save_directory.path_join(save_name).path_join("save_id.cfg")
	save_id.save(path_save_id)
		#endregion Save Date & Time
		
		#region Game Environment
	#Empties out the old values and sends out a request to all connected scripts to send their save data
	scene_data = []
	player_data = []
	object_data = []
	dialogue_data = []
	#Scene Data collection
	var dictionary_active_scenes = autoload_script_scene_manager.dictionary_active_scenes
	for scene in dictionary_active_scenes: 
		var scene_dictionary = {
			"Scene Name": scene,
			"Scene Path": dictionary_active_scenes[scene]["path"],
			"Current Canvas Layer": dictionary_active_scenes[scene]["canvas"].layer,
			"Current Visibility": dictionary_active_scenes[scene]["visibility"]
		}
		scene_data.append(scene_dictionary)
	#Requests save information from the other scripts
	autoload_script_signal_manager.emit_signal("request_save_info")
	var save_data_final = save_data_default.duplicate(true)
	save_data_final["Scene Info"] = scene_data
	save_data_final["Player Info"] = player_data
	save_data_final["Object Info"] = object_data
	save_data_final["Dialogue Info"] = dialogue_data
	#gets all children of the game_environment and checks if they are in the scene_level group
	var save_file_path = save_path.path_join("save_data.json")
	var save_data_file = FileAccess.open(save_file_path, FileAccess.WRITE)
	if save_data_file:
		save_data_file.store_string(JSON.stringify(save_data_final, "\t", 0))
		save_data_file.close()
	else:
		push_error("script_save_manager save_data_file failed to be created")
		#endregion Gamer Environment

		#region History
	var path_copy_destination = save_directory.path_join(save_name).path_join("history.json")
	if DirAccess.copy_absolute(history_file, path_copy_destination) !=OK:
		push_error("Failed to copy: ", history_file, "\nDestination: ", path_copy_destination)


## Recieves the dialogue save info and writes it to the dictionary
func receive_save_data(save_data_dictionary: Dictionary, signal_origin) -> void:
	match signal_origin:
		"player":
			for data in save_data_dictionary:
				player_data.append(save_data_dictionary[data])
			print("script_save_manager player_data merged with received data")
		"object":
			for data in save_data_dictionary:
				object_data.append(save_data_dictionary[data])
			print("script_save_manager object_data merged with received data")
		"dialogue":
			for data in save_data_dictionary:
				dialogue_data.append(save_data_dictionary[data])
			print("script_save_manager dialogue_data merged with received data")
		_:
			push_error("script_save_manager function receive_save_data has received an unrecognized dictionary")
	#endregion Save File Creation and Management


## Deletes save folders
func save_delete(save_name: String) -> void:
	var save_path = save_directory.path_join(save_name)
	#Since folders cannot be deleted with stuff inside of them, the for loop finds and 
	#deletes all items (not folders) inside of the save path before removing the folder. 
	if DirAccess.dir_exists_absolute(save_path):
		for file_name in DirAccess.get_files_at(save_path):
			var file_path = save_path.path_join(file_name)
			DirAccess.remove_absolute(file_path)
		DirAccess.remove_absolute(save_path)
		print("Save: ", save_name, " deleted at path: ", save_path)
	else:
		push_error("script_save_manager -> save_delete to determine save_path")
	#Final safty check to see if it fully deleted
	if DirAccess.dir_exists_absolute(save_path):
		push_error("script_save_manager -> save_delete failed to delete save folder")
#endregion Save Game Functionality


#region Checks
## Checks to see if the folder name is valid
func check_valid_folder_name(folder_name: String) -> bool:
	#This code returns true if the input string is a valid folder name
	#First checks if the string is empty
	if folder_name.is_empty() or folder_name.strip_edges().is_empty():
		return false
	
	# Windows folders that are invalid
	var win_reserved_names = [
		"CON", "PRN", "AUX", "NUL",
		"COM1", "COM2", "COM3", "COM4", "COM5", "COM6", "COM7", "COM8", "COM9",
		"LPT1", "LPT2", "LPT3", "LPT4", "LPT5", "LPT6", "LPT7", "LPT8", "LPT9"
	]
	if win_reserved_names.has(folder_name.to_upper()):
		return false
	
	# Characters invalid on both Windows and Linux
	var invalid_characters  = ['/', '\\', '<', '>', ':', '"', '|', '?', '*']
	for characters in invalid_characters :
		if folder_name.contains(characters ):
			return false
	
	#Checks for spaces and . at the begning and ends of folder names
	if folder_name.begins_with(".") or folder_name.ends_with(".") or \
		folder_name.begins_with(" ") or folder_name.ends_with(" "):
		return false    
	
	#Checks the folder length and returns true if it is below the length
	return folder_name.length() <= 255


## Checks to see if there is a duplicate save folder
func check_save_duplicate(save_name: String) -> bool:
	#Returns false if ther isn't a duplicate folder
	var save_path = save_directory+save_name
	print("Save Directory: ", save_path)
	#Checks to confirm if the save directory itself is detected
	if not DirAccess.dir_exists_absolute(save_directory):
		push_error("Save directory not found at: ", save_directory)
		return true
	#Checks to see if the a folder with the same name as the save_name exists
	if DirAccess.dir_exists_absolute(save_path):
		print("Save folder already exists")
		return true
	#If it can't find a duplicate
	return false
#endregion Checks


