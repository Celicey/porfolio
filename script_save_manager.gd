#Contains the functions meant to load and help load the game
#region Load Game Functionality
## Meant to load a save from a save folder
func load_game(save_name: String) -> void:
	var save_path = save_directory+save_name
	print("Save Directory: ", save_path)
	#Checks to see if directories exists before proceeding
	#region Directory Checks
	#Checks to see if the save_directory exists
	if not DirAccess.dir_exists_absolute(save_directory):
		push_error("Save directory not found at: ", save_directory)
		return 
	#Checks to see if the save_path exists
	if not DirAccess.dir_exists_absolute(save_path):
		push_error("Save path not found at: ", save_path)
		return 
	#endregion Directory Checks
	
	#Responsible for retreving the save data from the save_data.json in the save folder
	#region Data Retrieval 
	#Retrieves the save data as text
	var save_data
	var save_file = FileAccess.open(save_path.path_join("save_data.json"), FileAccess.READ)
	var save_file_text = save_file.get_as_text()
	save_file.close()
	#Converts the text data to json data and the json data to a save_data dictionary
	var json = JSON.new()
	var json_check = json.parse(save_file_text)
	if json_check == OK:
		save_data = json.data
		if typeof(save_data) == TYPE_DICTIONARY:
			print(save_data)
		else:
			push_error("Unexpected data type when loading save_data from: ", save_name)
			return
	else:
		push_error("JSON data failed to load in script_save_manager")
		return
	#endregion Data Retrieval
	
	#Loads the scenes and removes the old ones
	#region Scene Managment
	if save_data["Scene Info"].is_empty() != true:
		#Removes all scenes
		await autoload_script_scene_manager.scene_remove_all()
		var scene_info = save_data["Scene Info"]
		for scene in scene_info:
			print("Loading: ", scene["Scene Name"], " from: ", scene["Scene Path"])
			autoload_script_scene_manager.scene_load(scene["Scene Name"], scene["Scene Path"])
			#moves the loaded scene to the appropriate layer
			autoload_script_scene_manager.scene_layer_move(scene["Scene Name"], scene["Current Canvas Layer"])
			#adjusts visibility based on save data
			if scene["Current Visibility"] == true:
				autoload_script_scene_manager.scene_show(scene["Scene Name"])
			else:
				autoload_script_scene_manager.scene_hide(scene["Scene Name"])
		#Hides the escape menu if it was visible in the save since it can be visible when the player is saving. 
		autoload_script_scene_manager.scene_hide("scene_escape_menu")
	#endregion Scene Managment
	
	#Itterates over the objects in the save file and assigns the correct states
	#region Object Managment
	if save_data["Object Info"].is_empty() != true:
	#Objects in the scene are put into a dictionary as it is faster to search over that to find our values
		var interactable_objects = get_tree().get_nodes_in_group("interactables")
		var dictionary_interactable_objects = {}
		for node in interactable_objects:
			dictionary_interactable_objects[node.object_id] = node
		#For each object in the save data file, find the object in the scene and copy over the data
		for object in save_data["Object Info"]:
			if object["Object ID"] in dictionary_interactable_objects:
				var current_object = dictionary_interactable_objects[object["Object ID"]] 
				current_object.object_interaction_type = int(object["Object Interaction Type"])
				current_object.is_interactable = bool(object["Object is Interactable"])
				current_object.current_dialogue_segment = object["Current Dialogue Segment"]
	#endregion Object Managment
	
	#Itterates over the player dictionary to find the active player
	#region Player Managment
	#Finds and adds all members of the player group to a dictionary for faster referencing
	if save_data["Player Info"].is_empty() != true:
		var player_objects = get_tree().get_nodes_in_group("player")
		var dictionary_player_objects = {}
		for node in player_objects:
			dictionary_player_objects[node.player_id] = node
		#Assigns the data to the player object based on the save data
		for player in save_data["Player Info"]:
			var player_id = player["Player ID"]
			if player_id in dictionary_player_objects:
				var current_player = dictionary_player_objects[player["Player ID"]]
				#Tells the current player that it is being loaded in
				current_player.is_loading = true
				current_player.active = bool(player["Active"])
				#If the player is active, emit its state (only emitted once as if it is not the active player it doesn't act on the signal)
				if current_player.active == true:
					autoload_script_signal_manager.player_camera_bind.emit(player["Player Camera State"])
					autoload_script_signal_manager.player_movement.emit(player["Player Movement State"])
				#Breaks down the JSON input into an array of floats and then assigns those floats to the appropriate spots
				#Player Location: A Vector3 of the player location
				#Player Rotation: The rotation of the player body from left to right (the player doesn't look left and right through the camera, it is a full body rotation)
				#Player Camera X Rotation: The up and down of the camera
				var player_saved_position = regex_string_to_array(player["Player Location"])
				current_player.global_position = Vector3(player_saved_position[0], player_saved_position[1], player_saved_position[2])
				current_player.rotation.y = float(player["Player Rotation"])
				current_player.player_head.rotation.x = float(player["Player Camera X Rotation"])
				#Checks the player crouching state, and if crouched, make them crouched
				if player["Player Crouching State"] == true:
					current_player.crouching_state = true
					current_player.force_crouch()
				#Tells the player that it is finished loading
				current_player.is_loading = false
	#endregion Player Managment
	
	#Loads the dialogue into the game
	#region Dialogue Managment
	if save_data["Dialogue Info"].is_empty() != true:
		#There should only ever be one, so we can reference it directly like this (may be changed in the future)
		var dialogue_save_data = save_data["Dialogue Info"][0]
		if dialogue_save_data["Currently Talking"] == true:
			print("TEST TEST TEST WORKING")
			autoload_script_signal_manager.emit_signal("dialogue_object_id", dialogue_save_data["Object ID"])
			autoload_script_signal_manager.emit_signal("dialogue_segment_id", dialogue_save_data["Dialogue Segment"], dialogue_save_data["Dialogue Segment Index"])
			autoload_script_signal_manager.emit_signal("start_dialogue_display", dialogue_save_data["Dialogue Segment Index"])
		else:
			autoload_script_scene_manager.scene_remove("scene_dialogue_ui")
	#endregion Dialogue Managment
#endregion Load Game Functionality


#region Helper Functions
## This function takes in a provided string and extracts the floats from it, returning them in an array
#NOTE This used to be used more, but some changes to loading means that it is no longer used as much
#I am going to leave it here in case I need to use it again in the future. 
func regex_string_to_array(text: String) -> Array:
	var floats = []
	for match in regex.search_all(text):
		floats.append(float(match.get_string()))
	return floats
#endregion Helper Functions
